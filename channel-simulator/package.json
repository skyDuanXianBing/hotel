{
  "name": "channel-simulator",
  "version": "1.0.0",
  "description": "Su (SiteMinder) 渠道本地模拟测试系统",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "type-check": "tsc --noEmit && vue-tsc --noEmit -p tsconfig.app.json",
    "build": "tsc && vite build",
    "start": "node dist/index.js",
    "verify:local-e2e": "tsx src/scripts/verify-local-e2e.ts",
    "verify:channel-mapping": "tsx src/scripts/verify-channel-mapping.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "vue": "^3.5.34",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vue-tsc": "^3.3.1"
  }
}
