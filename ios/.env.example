# Copy this file to .env.local for personal overrides.
# .env.local is gitignored and is the right place to toggle local-only settings.

VITE_LOCAL_API_BASE_URL=https://pms.the-host.jp/api/v1
VITE_CLOUD_API_BASE_URL=https://pms.the-host.jp/api/v1
VITE_USE_CLOUD_API=true

# Set to true in .env.local when you want to use the frontend message mock.
VITE_USE_MESSAGE_MOCK=false

# Uncomment in .env.local only when you need to load the Su Widget on localhost.
# VITE_ALLOW_SU_WIDGET_LOCAL=true
