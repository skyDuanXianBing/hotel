# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/booking_system_db
DB_USERNAME=root
DB_PASSWORD=

# 服务器配置
SERVER_PORT=8092

# JWT配置
JWT_SECRET=your-256-bit-secret-key-for-jwt-token-generation-please-change-in-production

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 邮件配置
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=

# OpenAI GPT (recommended for inbox AI reply)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# Su Channel Manager API配置 (沙盒环境)
SU_API_BASE_URL=https://connect-sandbox.su-api.com
SU_CLIENT_ID=c2FpdG9zaG9qaWNvbHRkLnN1aXNzdS5jb20=
SU_CLIENT_SECRET=
SU_PMS_NAME=HostHub

# Su Messaging Webhook Basic Auth（生产环境建议配置；本地/沙盒可留空关闭鉴权）
SU_MESSAGING_WEBHOOK_USERNAME=
SU_MESSAGING_WEBHOOK_PASSWORD=
# Su Review Webhook：填写 Su 实际发送的完整 Authorization header 值；留空会禁用回调
SU_REVIEW_WEBHOOK_AUTHORIZATION=
SU_MESSAGING_AI_SENDER_NAME=AI客服
SU_MESSAGING_AI_MAX_INPUT_LENGTH=1200

# PriceLabs API配置
PRICELABS_API_BASE_URL=https://api.pricelabs.co/v1/integration/api
PRICELABS_INTEGRATION_NAME=thehosthub
PRICELABS_INTEGRATION_TOKEN=
PRICELABS_DEBUG=false

# 服务器基础URL（用于生成webhook回调地址）
SERVER_BASE_URL=http://localhost:8092

# Logging controls
LOG_PATH=logs
LOG_MAX_FILE_SIZE=100MB
LOG_MAX_HISTORY_DAYS=7
LOG_TOTAL_SIZE_CAP=2GB
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# S3 archive controls
S3_LOG_PREFIX=s3://your-bucket/prod/hotel
AWS_CLI_BIN=aws
LOG_ARCHIVE_MIN_AGE_MINUTES=30
LOG_DELETE_AFTER_UPLOAD=false
LOG_ARCHIVE_HOST_TAG=hotel-prod-a

# Local cleanup controls
LOG_RETAIN_DAYS=3
BACKEND_OUT_MAX_MB=200
